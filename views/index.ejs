<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Outfit', 'sans-serif'] },
                    animation: { 'gradient': 'gradient 15s ease infinite', 'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite' },
                    keyframes: {
                        gradient: {
                            '0%, 100%': { backgroundPosition: '0% 50%' },
                            '50%': { backgroundPosition: '100% 50%' },
                        }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <title>Premium Task Manager</title>
    <script>
        // Prevent FOUC flash
        if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>

<body class="bg-gradient-to-br from-indigo-50 via-white to-purple-50 dark:from-gray-900 dark:via-zinc-900 dark:to-indigo-950 min-h-screen text-zinc-800 dark:text-zinc-100 bg-[length:400%_400%] animate-gradient font-sans">
    <div class="main w-full min-h-screen px-5 md:px-10 lg:px-20 max-w-7xl mx-auto">
        <!-- Header -->
        <header class="flex flex-col sm:flex-row justify-between items-center py-12 gap-6">
            <div>
                <h1 class="text-5xl md:text-6xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-purple-600 dark:from-indigo-400 dark:to-purple-400 select-none tracking-tight">TaskFlow</h1>
                <p class="text-zinc-500 dark:text-zinc-400 mt-2 font-medium tracking-wide">Organize your life, beautifully.</p>
            </div>
            <button id="themeToggle" class="backdrop-blur-md bg-white/50 dark:bg-zinc-800/50 border border-zinc-200/50 dark:border-zinc-700/50 px-5 py-2.5 rounded-full font-semibold shadow-sm hover:shadow-md hover:bg-white/80 dark:hover:bg-zinc-700/80 transition-all duration-300 flex items-center gap-2">
                <span class="dark:hidden">🌙 Dark Mode</span>
                <span class="hidden dark:inline">☀️ Light Mode</span>
            </button>
        </header>

        <!-- Create Task Form -->
        <div class="mb-12">
            <form action="/files" method="post" class="backdrop-blur-xl bg-white/40 dark:bg-zinc-900/40 p-8 rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-white/60 dark:border-zinc-700/50 transition-all">
                <div class="flex flex-col lg:flex-row gap-6">
                    <div class="flex-1 space-y-5">
                        <div class="flex flex-col md:flex-row gap-5">
                            <input type="text" class="flex-1 h-14 rounded-2xl px-5 outline-none bg-white/90 dark:bg-black/20 focus:bg-white dark:focus:bg-black/40 shadow-inner border border-zinc-200 dark:border-transparent focus:border-indigo-500 dark:focus:border-indigo-500/50 transition-all duration-300 text-lg placeholder-zinc-400 font-medium"
                                placeholder="What needs to be done?" name="Title" required>
                            
                            <!-- Due Date Picker -->
                            <div class="relative">
                                <label class="absolute -top-2.5 left-4 bg-white dark:bg-zinc-800 px-2 text-xs font-bold text-indigo-500 rounded-full shadow-sm border border-zinc-100 dark:border-zinc-700">Due Date</label>
                                <input type="date" class="h-14 rounded-2xl px-5 outline-none bg-white/90 dark:bg-black/20 focus:bg-white dark:focus:bg-black/40 shadow-inner border border-zinc-200 dark:border-transparent focus:border-indigo-500 dark:focus:border-indigo-500/50 transition-all duration-300 font-medium text-zinc-600 dark:text-zinc-300 w-full md:w-48 color-scheme-light dark:[color-scheme:dark]" name="dueDate">
                            </div>
                        </div>
                        
                        <textarea class="resize-none w-full h-24 rounded-2xl p-5 outline-none bg-white/90 dark:bg-black/20 focus:bg-white dark:focus:bg-black/40 shadow-inner border border-zinc-200 dark:border-transparent focus:border-indigo-500 dark:focus:border-indigo-500/50 transition-all duration-300 placeholder-zinc-400 font-medium"
                            placeholder="Add some details... (optional)" name="details"></textarea>
                    </div>
                    <div class="flex flex-col justify-end">
                        <button type="submit" class="h-14 px-8 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 text-white rounded-2xl cursor-pointer font-bold shadow-lg shadow-indigo-500/30 hover:shadow-indigo-500/50 hover:-translate-y-1 transition-all duration-300">
                            Create Task
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Search & Filter Bar -->
        <div class="mb-8 flex flex-col md:flex-row gap-4 items-center justify-between bg-white/30 dark:bg-zinc-800/30 p-4 rounded-2xl border border-white/50 dark:border-zinc-700/50 backdrop-blur-md">
            <form action="/" method="GET" class="w-full md:w-auto flex-1 flex gap-3">
                <!-- Keep current filter when searching -->
                <input type="hidden" name="filter" value="<%= filterQuery %>">
                <div class="relative w-full max-w-md">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                    <input type="text" name="search" value="<%= searchQuery %>" placeholder="Search tasks..." class="w-full h-12 pl-11 pr-4 rounded-xl outline-none bg-white/90 dark:bg-black/30 focus:bg-white dark:focus:bg-black/50 shadow-inner border border-zinc-200 dark:border-transparent focus:border-indigo-500 dark:focus:border-indigo-500/50 transition-all font-medium placeholder-zinc-400">
                </div>
                <button type="submit" class="px-6 h-12 bg-zinc-800 dark:bg-zinc-700 text-white rounded-xl font-semibold hover:bg-zinc-700 dark:hover:bg-zinc-600 transition-colors shadow-sm">Search</button>
                <% if (searchQuery) { %>
                    <a href="/?filter=<%= filterQuery %>" class="px-4 h-12 flex items-center bg-rose-100 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400 rounded-xl font-semibold hover:bg-rose-200 dark:hover:bg-rose-900/50 transition-colors">Clear</a>
                <% } %>
            </form>

            <div class="flex gap-2 p-1 bg-zinc-200/50 dark:bg-black/30 rounded-xl">
                <a href="/?filter=all<%= searchQuery ? '&search=' + searchQuery : '' %>" class="px-5 py-2 rounded-lg font-semibold text-sm transition-all <%= filterQuery === 'all' ? 'bg-white dark:bg-zinc-700 text-indigo-600 dark:text-indigo-400 shadow-sm' : 'text-zinc-500 hover:text-zinc-700 dark:hover:text-zinc-300' %>">All</a>
                <a href="/?filter=pending<%= searchQuery ? '&search=' + searchQuery : '' %>" class="px-5 py-2 rounded-lg font-semibold text-sm transition-all <%= filterQuery === 'pending' ? 'bg-white dark:bg-zinc-700 text-indigo-600 dark:text-indigo-400 shadow-sm' : 'text-zinc-500 hover:text-zinc-700 dark:hover:text-zinc-300' %>">Pending</a>
                <a href="/?filter=completed<%= searchQuery ? '&search=' + searchQuery : '' %>" class="px-5 py-2 rounded-lg font-semibold text-sm transition-all <%= filterQuery === 'completed' ? 'bg-white dark:bg-zinc-700 text-indigo-600 dark:text-indigo-400 shadow-sm' : 'text-zinc-500 hover:text-zinc-700 dark:hover:text-zinc-300' %>">Completed</a>
            </div>
        </div>
        
        <!-- Tasks Grid -->
        <div class="tasks grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 pb-20">
            <% 
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            
            if (tasks && tasks.length > 0) { 
                tasks.forEach(function(task){ 
                    let urgencyClass = '';
                    let urgencyText = '';
                    
                    if (task.dueDate && task.status !== 'completed') {
                        const dueDate = new Date(task.dueDate);
                        // Reset time for fair comparison
                        const dueOnly = new Date(dueDate.getFullYear(), dueDate.getMonth(), dueDate.getDate());
                        
                        if (dueOnly < today) {
                            urgencyClass = 'bg-rose-100/80 dark:bg-rose-900/40 text-rose-700 dark:text-rose-300 border-rose-200 dark:border-rose-800 animate-pulse-slow';
                            urgencyText = 'Overdue';
                        } else if (dueOnly.getTime() === today.getTime()) {
                            urgencyClass = 'bg-amber-100/80 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300 border-amber-200 dark:border-amber-800';
                            urgencyText = 'Due Today';
                        } else {
                            urgencyClass = 'bg-blue-50/80 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 border-blue-100 dark:border-blue-800/50';
                            urgencyText = 'Due ' + dueOnly.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
                        }
                    }
            %>
                    <div class="group relative backdrop-blur-xl bg-white/60 dark:bg-zinc-900/60 p-7 rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_20px_40px_rgb(0,0,0,0.08)] dark:shadow-none border border-white/60 dark:border-zinc-700/50 flex flex-col justify-between transition-all duration-500 hover:-translate-y-2 <%= task.status === 'completed' ? 'opacity-50 grayscale-[30%] hover:opacity-100 hover:grayscale-0' : '' %>">
                        
                        <div class="absolute inset-0 bg-gradient-to-br <%= task.status === 'completed' ? 'from-green-500/5' : 'from-indigo-500/5' %> to-transparent rounded-3xl pointer-events-none"></div>

                        <div class="relative z-10">
                            <!-- Urgency Badge -->
                            <% if (urgencyText) { %>
                                <div class="absolute -top-3 -right-3">
                                    <span class="px-3 py-1 text-xs font-bold uppercase tracking-wider rounded-full border shadow-sm <%= urgencyClass %>">
                                        <%= urgencyText %>
                                    </span>
                                </div>
                            <% } %>

                            <div class="flex justify-between items-start mb-4 gap-4">
                                <h1 class="text-2xl font-bold leading-tight <%= task.status === 'completed' ? 'line-through text-zinc-400 dark:text-zinc-500' : 'text-zinc-800 dark:text-zinc-100' %>">
                                    <%= task.title %>
                                </h1>
                                <form action="/files/<%= task.id %>/toggle" method="POST" class="m-0 p-0 flex-shrink-0 pt-1">
                                    <input type="checkbox" onchange="this.form.submit()" class="w-6 h-6 cursor-pointer rounded-lg border-zinc-300 text-indigo-600 focus:ring-indigo-500/50 transition-all duration-300 shadow-sm" <%= task.status === 'completed' ? 'checked' : '' %>>
                                </form>
                            </div>
                            <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-6 line-clamp-3 whitespace-pre-wrap font-medium leading-relaxed"><%= task.details || 'No details provided.' %></p>
                        </div>
                        
                        <div class="relative z-10 flex justify-between items-center mt-auto border-t border-zinc-200/50 dark:border-zinc-700/50 pt-5">
                            <span class="text-xs text-zinc-400 dark:text-zinc-500 font-semibold tracking-wider uppercase">
                                Created <%= new Date(task.createdAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric' }) %>
                            </span>
                            <div class="flex gap-4 opacity-70 group-hover:opacity-100 transition-opacity duration-300">
                                <a class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 text-sm font-bold transition-colors" href="/files/<%= task.id %>">View</a>
                                <a class="text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300 text-sm font-bold transition-colors" href="/files/<%= task.id %>/edit">Edit</a>
                                <a class="text-rose-500 dark:text-rose-400 hover:text-rose-700 dark:hover:text-rose-300 text-sm font-bold transition-colors" href="/files/<%= task.id %>/delete">Del</a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-span-full w-full text-center py-20 backdrop-blur-xl bg-white/40 dark:bg-zinc-900/40 rounded-3xl border border-white/60 dark:border-zinc-700/50 shadow-sm">
                    <div class="inline-flex p-6 rounded-full bg-gradient-to-br from-indigo-100 to-purple-100 dark:from-indigo-900/30 dark:to-purple-900/30 mb-6 shadow-inner">
                        <svg class="w-12 h-12 text-indigo-500 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path></svg>
                    </div>
                    <h1 class="text-zinc-800 dark:text-zinc-200 text-3xl font-bold tracking-tight">
                        <%= searchQuery || filterQuery !== 'all' ? 'No tasks found' : 'Your space is clear' %>
                    </h1>
                    <p class="text-zinc-500 dark:text-zinc-400 mt-3 text-lg font-medium">
                        <%= searchQuery || filterQuery !== 'all' ? 'Try adjusting your search or filters.' : 'Create your first task above to begin.' %>
                    </p>
                </div>
            <% } %>
        </div>
    </div>
    
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script>
        // Dark Mode Toggle Logic
        const themeToggleBtn = document.getElementById('themeToggle');

        themeToggleBtn.addEventListener('click', function() {
            if (localStorage.getItem('color-theme')) {
                if (localStorage.getItem('color-theme') === 'light') {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('color-theme', 'dark');
                } else {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('color-theme', 'light');
                }
            } else {
                if (document.documentElement.classList.contains('dark')) {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('color-theme', 'light');
                } else {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('color-theme', 'dark');
                }
            }
        });

        // Premium Toast Notifications
        const urlParams = new URLSearchParams(window.location.search);
        const successMsg = urlParams.get('success');
        const errorMsg = urlParams.get('error');

        const toastConfig = {
            duration: 4000,
            gravity: "bottom", 
            position: "right",
            style: { 
                borderRadius: "16px", 
                fontWeight: "600",
                fontFamily: "Outfit, sans-serif",
                padding: "16px 24px",
                boxShadow: "0 10px 40px rgba(0,0,0,0.1)",
                backdropFilter: "blur(10px)",
                border: "1px solid rgba(255,255,255,0.1)"
            }
        };

        if (successMsg) {
            Toastify({
                ...toastConfig,
                text: successMsg,
                style: { ...toastConfig.style, background: "linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%)" }
            }).showToast();
            window.history.replaceState(null, '', window.location.pathname);
        }
        
        if (errorMsg) {
            Toastify({
                ...toastConfig,
                text: errorMsg,
                style: { ...toastConfig.style, background: "linear-gradient(135deg, #ef4444 0%, #b91c1c 100%)" }
            }).showToast();
            window.history.replaceState(null, '', window.location.pathname);
        }
    </script>
</body>
</html>